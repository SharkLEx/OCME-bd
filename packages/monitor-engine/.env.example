# ==============================================================================
# .env.example — OCME bd Monitor Engine
# Copie para .env e preencha com seus valores reais
# NUNCA commite o .env real no repositório
# ==============================================================================

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=SEU_TOKEN_AQUI
BOT_TOKEN=SEU_TOKEN_AQUI  # alias (use um dos dois)

# ── Wallet principal ──────────────────────────────────────────────────────────
WALLET_ADDRESS=0xSUA_WALLET_AQUI

# ── Blockchain / RPC ──────────────────────────────────────────────────────────
# Alchemy (recomendado para Polygon Mainnet)
RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/SUA_CHAVE_ALCHEMY
RPC_CAPITAL=https://polygon-mainnet.g.alchemy.com/v2/SUA_CHAVE_ALCHEMY_CAPITAL

# Polygonscan (para auditoria de gas)
POLYGONSCAN_API_KEY=SUA_CHAVE_POLYGONSCAN

# ── Inteligência Artificial ────────────────────────────────────────────────────
# Opção 1: OpenRouter (suporta múltiplos modelos)
OPENROUTER_API_KEY=

# Opção 2: OpenAI direto
OPENAI_API_KEY=

# Modelo (exemplos: gpt-4.1-nano, gpt-4o-mini, openai/gpt-4.1-nano)
OPENAI_MODEL=gpt-4.1-nano
OPENAI_DEFAULT_ON=1

# ── Banco de dados ────────────────────────────────────────────────────────────
DB_PATH=webdex_v5_final.db
# Para Docker: DB_PATH=/app/data/webdex_v5_final.db

# ── Administradores (chat_ids do Telegram separados por vírgula) ───────────────
ADMIN_USER_IDS=SEU_CHAT_ID_AQUI
OWNER_CHAT_ID=SEU_CHAT_ID_AQUI

# ── Contratos por ambiente (opcional — padrões já configurados) ───────────────
# AG_C_bd
# AG_C_BD_PAYMENTS=0x96bF20B20de9c01D5F1f0fC74321ccC63E3f29F1
# AG_C_BD_SUBACCOUNTS=0x14eEd4F2Bfcfd85E2262987Cf8cbcD97B02557ca

# bd_v5
# BD_V5_PAYMENTS=0x48748959392e9fa8a72031c51593dcf52572e120
# BD_V5_SUBACCOUNTS=0x6995077c49d920D8516AF7b87a38FdaC5E2c957C

# ── Tokens (opcional — padrões já configurados) ────────────────────────────────
# TOKEN_USDT_ADDRESS=0xc2132D05D31c914a87C6611C10748AEb04B58e8F
# TOKEN_LOOP_ADDRESS=0xc4CF5093676e8a61404f51bC6Ceaec5279Ce8645
# TOKEN_LP_ADDRESS=0xFb2e2Ff7B51C2BcAf58619a55e7d2Ff88cFD8aCA,0xB56032D0B576472b3f0f1e4747f488769dE2b00B

# ── Monitor (performance — ajuste conforme necessidade) ──────────────────────
MONITOR_MAX_BLOCKS_PER_LOOP=80
MONITOR_FETCH_CHUNK=25
MONITOR_IDLE_SLEEP=1.2
MONITOR_BUSY_SLEEP=0.25
MONITOR_TRANSFER_EVERY_N=3
MONITOR_BACKLOG_WARN_AT=20

# ── Limites / Sentinela ───────────────────────────────────────────────────────
LIMITE_GWEI=1000
LIMITE_SALDO_GAS=2
LIMITE_INATIV_MIN=30

# ── Módulos Epic 7 (monitor-core, monitor-ai, monitor-report) ──────────────
# Sentinela (monitor-core)
SENTINELA_GAS_USD_MAX=2.0
SENTINELA_GWEI_MAX=1000
SENTINELA_INACTIVITY_MINUTES=30
SENTINELA_RPC_ERRORS_MAX=5

# Dashboard Cache (monitor-report)
DASHBOARD_CACHE_TTL=15

# IA Contextual (monitor-ai)
AI_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_API_KEY e OPENAI_MODEL acima

# CLI (monitor-cli)
OCME_DB_PATH=packages/monitor-engine/webdex_v5_final.db

# ── Discord Webhooks (categoria ⚡ PROTOCOLO AO VIVO) ─────────────────────────
# Obter em: Discord → Canal → Configurações → Integrações → Webhooks
DISCORD_WEBHOOK_ONCHAIN=https://discord.com/api/webhooks/ID/TOKEN
DISCORD_WEBHOOK_OPERACOES=https://discord.com/api/webhooks/ID/TOKEN
DISCORD_WEBHOOK_SWAPS=https://discord.com/api/webhooks/ID/TOKEN
DISCORD_WEBHOOK_RELATORIO=https://discord.com/api/webhooks/ID/TOKEN
DISCORD_WEBHOOK_GM=https://discord.com/api/webhooks/ID/TOKEN
DISCORD_WEBHOOK_TOKEN_BD=https://discord.com/api/webhooks/ID/TOKEN
DISCORD_WEBHOOK_CONQUISTAS=https://discord.com/api/webhooks/ID/TOKEN
# Epic 19 — Canal dedicado movimentações Sub v4 (relatório 2h)
DISCORD_WEBHOOK_V4_SUB=https://discord.com/api/webhooks/ID/TOKEN

# ── Replicate (bdZinho animações) ─────────────────────────────────────────────
# Obter em: https://replicate.com/account/api-tokens
REPLICATE_TOKEN=r8_SEU_TOKEN_AQUI

# ── Creatomate (vídeos branded — Relatório 21h) ───────────────────────────────
# API Key: Creatomate Dashboard → Settings → API Keys (NÃO é o Public Token)
CREATOMATE_API_KEY=SEU_API_KEY_AQUI
# CREATOMATE_TEMPLATE_21H — DEPRECATED: creatomate_worker.py usa source JSON inline (v2).
# Template ID não é mais necessário. Mantido apenas para referência histórica.
# CREATOMATE_TEMPLATE_21H=8be3eb11-df12-4480-9dd3-7acd9c6e8d0e

# ── Observability (Story 7.7) ─────────────────────────────────────────────────
# Porta do servidor HTTP de métricas Prometheus e health check
METRICS_PORT=9090

# ── Log rotation (configurado em webdex_config.py) ────────────────────────────
# Tamanho máximo do log antes de rotacionar: 5MB
# LOG_MAX_BYTES=5242880  # padrão já configurado no código
# Número de arquivos de backup: 3
# LOG_BACKUP_COUNT=3     # padrão já configurado no código
